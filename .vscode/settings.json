{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.ruffEnabled": true,
  "python.linting.ruffArgs": [
    "--extend-select=E501,W,F,I,UP,N",
    "--line-length=120"
  ],
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.include": ["src/**", "eval/**", "tests/**"],
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.executeInFileDir": true,
  "pylance.analysis.typeCheckingMode": "strict",
  
  "jupyter.runStartupCommands": [
    "import sys; sys.path.insert(0, '${workspaceFolder}/src')"
  ],
  "jupyter.notebookFileRoot": "${workspaceFolder}/notebooks",
  
  "editor.rulers": [88, 120],
  "editor.wordWrapColumn": 120,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.defaultFormatter": "charliermarsh.ruff",
  "editor.inlayHints.enabled": true,
  
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    ".pytest_cache": true,
    ".mypy_cache": true
  },
  "files.watcherExclude": {
    "**/__pycache__": true
  },
  
  "errorLens.excludeBySource": ["Pylance"],
  "errorLens.enabled": true,
  "errorLens.followCursorMore": true,
  
  "workbench.colorCustomizations": {
    "editorError.foreground": "#ff6b6b",
    "editorWarning.foreground": "#ffd93d"
  },
  
  "debug.console.fontSize": 12,
  "debug.console.wordWrap": true,
  
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/.git": true
  },
  "logFileHighlighter.customPatterns": [
    {
      "pattern": "agent_start",
      "foreground": "#00ff00"
    },
    {
      "pattern": "tool_call",
      "foreground": "#ffff00"
    },
    {
      "pattern": "ERROR",
      "foreground": "#ff0000"
    }
  ]
}
